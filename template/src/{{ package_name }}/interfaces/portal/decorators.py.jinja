from __future__ import annotations

from collections.abc import Callable
from functools import wraps
from typing import Any

from django.http import HttpRequest, HttpResponseBase
from django.shortcuts import redirect

from {{ package_name }}.interfaces.common import permissions


def portal_login_required(
    view_func: Callable[..., HttpResponseBase],
) -> Callable[..., HttpResponseBase]:
    """Portal auth — separate from Django admin auth.

    Extend here with membership/role checks as the project grows
    (see the handbook's tenancy ladder).
    """

    @wraps(view_func)
    def wrapper(request: HttpRequest, *args: Any, **kwargs: Any) -> HttpResponseBase:
        if not request.user.is_authenticated:
            return redirect(permissions.login_redirect_url(request))
        return view_func(request, *args, **kwargs)

    return wrapper
