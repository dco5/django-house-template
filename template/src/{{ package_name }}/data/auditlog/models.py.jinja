from __future__ import annotations

from django.conf import settings
from django.db import models

from {{ package_name }}.data.common.constants import ActionSource
from {{ package_name }}.data.common.models import BaseModel


class AuditLog(BaseModel):
    """Immutable audit trail. Written by domain operations only — never updated or deleted."""

    action = models.CharField(max_length=100)
    actor = models.ForeignKey(
        settings.AUTH_USER_MODEL,
        on_delete=models.PROTECT,
        related_name="audit_logs",
        null=True,
        blank=True,
    )
    action_source = models.CharField(max_length=20, choices=ActionSource.choices)
    object_type = models.CharField(max_length=100)
    object_id = models.CharField(max_length=64)
    changes = models.JSONField(default=dict, blank=True)

    class Meta(BaseModel.Meta):
        indexes = [
            models.Index(fields=["object_type", "object_id"]),
        ]

    def __str__(self) -> str:
        return f"{self.action} {self.object_type}:{self.object_id} by {self.actor}"
