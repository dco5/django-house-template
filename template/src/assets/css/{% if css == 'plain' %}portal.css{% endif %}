:root {
  --primary: #1f2937;
  --accent: #b8860b;
  --bg: #f9fafb;
}

body {
  font-family: system-ui, sans-serif;
  background: var(--bg);
  color: var(--primary);
  margin: 0;
}

.container {
  max-width: 960px;
  margin: 0 auto;
  padding: 2rem 1rem;
}

label { display: block; margin: 0.5rem 0; }

button {
  background: var(--accent);
  color: white;
  border: none;
  padding: 0.5rem 1rem;
  border-radius: 4px;
  cursor: pointer;
}

.message { padding: 0.75rem 1rem; border-radius: 4px; margin-bottom: 1rem; }
.message-success { background: #d1fae5; }
.message-error { background: #fee2e2; }
.message-warning { background: #fef3c7; }
