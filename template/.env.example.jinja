# Copy to .env and fill in. Never commit .env.
SECRET_KEY=change-me-to-a-50-plus-char-random-string-change-me-now
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
{% if database == "postgres" %}
DATABASE_URL=postgres://{{ package_name }}:{{ package_name }}@localhost:5432/{{ package_name }}
{% else %}
# SQLite path is relative to src/ (see settings)
DATABASE_PATH=db.sqlite3
{% endif %}
{% if use_celery %}
REDIS_URL=redis://localhost:6379/0
{% endif %}
{% if use_api %}
INTERNAL_API_TOKEN=dev-token-change-in-production
{% endif %}
{% if use_sentry %}
SENTRY_DSN=
{% endif %}
