# Copy to .env and fill in. Never commit .env.
# DEBUG is not read from env — it is fixed per settings module (local/test/production).
SECRET_KEY=change-me-to-a-50-plus-char-random-string-change-me-now
ALLOWED_HOSTS=localhost,127.0.0.1
{% if database == "postgres" %}
DATABASE_URL=postgres://{{ package_name }}:{{ package_name }}@localhost:5432/{{ package_name }}
{% else %}
# SQLite path is relative to src/ (see settings)
DATABASE_PATH=db.sqlite3
{% endif %}
{% if use_celery %}
REDIS_URL=redis://localhost:6379/0
{% endif %}
{% if use_api %}
# Production refuses to start with this default value — generate a real secret.
INTERNAL_API_TOKEN=dev-token-change-in-production
{% endif %}
{% if use_sentry %}
SENTRY_DSN=
{% endif %}
