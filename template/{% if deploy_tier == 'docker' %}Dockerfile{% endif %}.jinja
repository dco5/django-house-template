FROM python:3.13-slim AS builder

COPY --from=ghcr.io/astral-sh/uv:latest /uv /usr/local/bin/uv

ENV UV_COMPILE_BYTECODE=1 UV_LINK_MODE=copy
WORKDIR /code

RUN apt-get update && apt-get install -y --no-install-recommends \
    build-essential curl{% if database == "postgres" %} libpq-dev{% endif %} \
    && rm -rf /var/lib/apt/lists/*

COPY pyproject.toml uv.lock ./
RUN uv sync --locked --no-dev --no-install-project

COPY . .
{% if css == "tailwind" %}
ENV SECRET_KEY=build-time-only DJANGO_SETTINGS_MODULE=config.settings.test
RUN cd src && uv run python manage.py tailwind build
{% endif %}
RUN cd src && SECRET_KEY=build-time-only DJANGO_SETTINGS_MODULE=config.settings.test \
    uv run python manage.py collectstatic --noinput

FROM python:3.13-slim

RUN apt-get update && apt-get install -y --no-install-recommends \
    {% if database == "postgres" %}libpq5 {% endif %}curl \
    && rm -rf /var/lib/apt/lists/* \
    && groupadd -r app && useradd -r -g app app

COPY --from=builder /code /code
ENV PATH="/code/.venv/bin:$PATH" DJANGO_SETTINGS_MODULE=config.settings.production

WORKDIR /code/src
USER app
EXPOSE 8000

CMD ["gunicorn", "config.wsgi:application", "--bind", "0.0.0.0:8000", "--workers", "3"]
